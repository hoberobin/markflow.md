# markflow.md server port (default 4000)
PORT=4000

# When the Node server should serve the Vite build (same-origin real-time collab).
# Example: ../client/dist or /app/client-dist in Docker.
# CLIENT_DIST=

# Client API base (optional). Leave empty to use the page origin (same-origin collab).
# Needed for split static+API deploys, or Docker Compose client (see README).
# Example: https://markflowmd-api.onrender.com
VITE_SERVER_URL=

# Client WebSocket URL (optional). If omitted, derived from collab HTTP base above or page origin.
VITE_WS_URL=
