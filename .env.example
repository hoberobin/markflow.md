# markflow.md server port (default 4000)
PORT=4000

# Client API base URL (optional in local dev)
# Example: https://markflowmd-api.onrender.com
VITE_SERVER_URL=

# Client WebSocket base URL (optional)
# If omitted, the client derives ws/wss from VITE_SERVER_URL.
VITE_WS_URL=

# SQLite database location for the server
# DATABASE_PATH=./data/markflow.db
